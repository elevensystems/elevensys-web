{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": ["Bash(npx next build:*)", "Bash(npx next lint:*)", "Bash(npx eslint:*)", "Bash(node -e:*)", "Bash(npx prettier:*)"]
  },
  "enabledMcpjsonServers": ["next-devtools", "shadcn"],
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  }
}
