{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npx next build:*)",
      "Bash(npx next lint:*)",
      "Bash(npx eslint:*)",
      "Bash(node -e:*)",
      "Bash(npx prettier:*)",
      "Bash(npx tsc:*)",
      "mcp__next-devtools__nextjs_docs",
      "Bash(pnpm exec eslint:*)",
      "Bash(grep:*)",
      "mcp__shadcn__search_items_in_registries",
      "mcp__shadcn__view_items_in_registries",
      "WebFetch(domain:ui.shadcn.com)",
      "Bash(git checkout -- src/app/timesheet/project-worklogs/page.tsx src/hooks/use-project-worklogs.ts src/app/api/timesheet/project-worklogs/route.ts)",
      "Bash(npm run build)",
      "Bash(npm test)"
    ]
  },
  "enabledMcpjsonServers": ["next-devtools", "shadcn"],
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  }
}
