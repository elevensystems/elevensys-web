{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npx next build:*)",
      "Bash(npx next lint:*)",
      "Bash(npx eslint:*)",
      "Bash(node -e:*)",
      "Bash(npx prettier:*)",
      "Bash(npx tsc:*)",
      "mcp__next-devtools__nextjs_docs",
      "Bash(pnpm exec eslint:*)",
      "Bash(grep:*)",
      "mcp__shadcn__search_items_in_registries",
      "mcp__shadcn__view_items_in_registries",
      "WebFetch(domain:ui.shadcn.com)",
      "Bash(git checkout -- src/app/timesheet/project-worklogs/page.tsx src/hooks/use-project-worklogs.ts src/app/api/timesheet/project-worklogs/route.ts)",
      "Bash(npm run build)",
      "Bash(npm test)",
      "mcp__shadcn__get_item_examples_from_registries",
      "Bash(npm run lint)",
      "Bash(npx jest src/app/timesheet/worklogs/page.test.tsx src/app/timesheet/config/page.test.tsx --verbose)",
      "Bash(npx jest src/app/tools/urlify/page.test.tsx --no-coverage)",
      "Bash(git status -u)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh repo:*)",
      "Bash(git checkout:*)",
      "Bash(gh pr:*)",
      "Bash(python3:*)",
      "Bash(git show:*)",
      "mcp__next-devtools__nextjs_index",
      "Bash(vercel flags:*)",
      "Bash(npx vercel:*)"
    ]
  },
  "enabledMcpjsonServers": ["next-devtools", "shadcn", "sentry", "context7"],
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  }
}
